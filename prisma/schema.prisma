generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Volunteer {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  city      String?
  interests String
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([email])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([email])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  startsAt    DateTime
  location    String
  description String
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startsAt])
  @@index([isPublished])
}

model Endorsement {
  id          String   @id @default(cuid())
  name        String
  role        String
  quote       String
  category    String   @default("Community Supporter")
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isPublished])
}

model NewsPost {
  id          String   @id @default(cuid())
  title       String
  excerpt     String
  body        String
  slug        String   @unique
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
